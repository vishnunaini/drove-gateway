# Generated by nixy {{datetime}}

global
  # daemon ignored in systemd mode -Ws
  # master-worker #default in systemd mode as -Ws is used
  # mworker-max-reloads 3 #implies how many reloads a worker will survive
  chroot /var/lib/haproxy
  user haproxy
  group haproxy
  # stats socket ipv4@127.0.0.1:9999 level admin #user/operator/admin
  stats socket ipv4@127.0.0.1:9999 level admin
  stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners # expose fd listeners for dataplaneapi service
  stats timeout 30s
  log /dev/log local0
  log /dev/log local1 notice
  node {{ .Xproxy }}
  stats maxconn 40
  # server-state-file /var/lib/haproxy/server-state
  #systemd ExecReload can be used to write and load server state file if using server-template's

defaults nixy_defaults
  mode http
  log global
  option httplog
  option dontlognull
  log-format '%ci %tr "%r" %ST %TR %si:%sp %B %{+Q}hrl %sslv/%sslc %b'
  option http-keep-alive # keep client facing and server facing connection alive - default
  option forwardfor
  timeout connect 30s # nginx proxy_connect_timeout
  timeout client 10s  #client keep alive
  timeout client-fin 10s
  timeout queue 10s # timeout waiting for maxconn queue
  timeout server 120s # nginx proxy_read_timeout
  timeout tunnel 30m # timeout to use with WebSocket and CONNECT
  timeout http-keep-alive 10s # nginx keepalive_timeout
  errorfile 400 /etc/haproxy/errors/400.http
  errorfile 403 /etc/haproxy/errors/403.http
  errorfile 408 /etc/haproxy/errors/408.http
  errorfile 500 /etc/haproxy/errors/500.http
  errorfile 502 /etc/haproxy/errors/502.http
  errorfile 503 /etc/haproxy/errors/503.http
  errorfile 504 /etc/haproxy/errors/504.http
  # load-server-state-from-file global

frontend stats
    mode http
    bind 127.0.0.1:3000
    stats enable
    stats uri /stats
    stats hide-version
    stats refresh 2s

frontend https_in
  mode http
  bind :80

  capture request  header Host len 128
  capture request  header Referer len 256
  capture request  header User-Agent len 256
  capture request  header X-Forwarded-For len 256
  capture request  header X-Request-Env len 256

  # http-response set-header X-Proxy {{ .Xproxy }}
  #Websockets
  acl hdr_connection_upgrade hdr(Connection)  -i upgrade
  acl hdr_upgrade_websocket  hdr(Upgrade)     -i websocket
  http-request add-header Connection upgrade if hdr_upgrade_websocket !hdr_connection_upgrade

  acl header_env_present req.hdr(X-Request-Env) -m found

  # for header based routing matching use regex match only as str matching has a limit of 64 words for acl, i.e more than 64 header value's will not be a valid config
  # for hierarchical add http-request replace-header logic to truncate headers accordingly
  {{- range $id, $app := .Apps}}

  acl host_{{$id}} hdr(host) -i {{$id}}
  #since we are using regex, there should be a reserved header like none
  acl env_in_list_{{$id}} hdr_reg(X-Request-Env) ({{- range $gid, $hostgrp := .Groups}}^{{$gid}}$|{{- end}}^none$)

  {{- end}}

  {{- range $id, $app := .Apps}}
  use_backend %[req.hdr(host),lower,word(1,:)]{{ $.HaproxyBackendNameSeparator }}%[req.hdr(X-Request-Env),lower] if env_in_list_{{$id}} header_env_present
  {{- end}}

  #send to default env if no header is present or is empty
  #use_backend <add logic here> if !header_env_present

  default_backend no-match

{{- range $id, $app := .Apps}}
 {{- range $gid, $hostgrp := .Groups}}
backend {{$id}}{{ $.HaproxyBackendNameSeparator }}{{$gid}}
  mode http
  balance roundrobin
  http-request replace-header Host .* {{$app.Vhost}}

  {{- range $hostgrp.Hosts}}
  {{- if eq .PortType "https"}}
  server {{ $.HaproxyServerNamePrefix }}{{ $.HaproxyServerNameHostPortSeparator }}{{ .Host }}_{{ .Port }} {{ .Host }}:{{ .Port }} {{$.HaproxyAddServerAttributesString}} {{$.HaproxyAddServerSSLAttributesString}}
  {{- else if eq .PortType "http"}}
  server {{ $.HaproxyServerNamePrefix }}{{ $.HaproxyServerNameHostPortSeparator }}{{ .Host }}_{{ .Port }} {{ .Host }}:{{ .Port }} {{$.HaproxyAddServerAttributesString}}
  {{- else if eq .PortType "tcp"}}
  #skipped plain tcp upstream server_{{ .Host }}_{{ .Port }}
  {{- else if eq .PortType "udp"}}
  #skipped plain udp upstream server_{{ .Host }}_{{ .Port }}
	{{- end}}
  {{- end}}
 {{- end}}
{{- end}}

backend no-match from pp_defaults
  mode http
  http-request deny deny_status 404
