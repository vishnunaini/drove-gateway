[Unit]
Description=Drove Gateway - Nginx/HAProxy proxy for Drove
Documentation=https://github.com/phonepe/drove-gateway
After=network.target nss-lookup.target
Wants=nginx.service haproxy.service nss-lookup.target
StartLimitIntervalSec=0

[Service]
LimitNOFILE=65000
LimitNPROC=65000
Type=simple
Restart=always
RestartSec=1
User=root
WorkingDirectory=/etc/nixy
ExecStart=/usr/bin/nixy -f /etc/nixy/nixy.toml
SyslogIdentifier=nixy

[Install]
WantedBy=multi-user.target
Alias=nixy.service

